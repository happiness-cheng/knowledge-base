# Knowledge Base 环境变量配置
# 复制此文件为 .env 并填入实际值

# 数据库（本地开发用 SQLite，服务器部署用 MySQL）
DATABASE_URL=mysql+pymysql://root:your_password@mysql:3306/knowledge_base

# AI 配置（管理员默认 Key，用户可在应用内配置自己的）
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL_NAME=deepseek-chat

# JWT 密码签名密钥（务必改成随机字符串）
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# CORS 允许的前端域名
# 本地开发不用改，部署时改成你的域名
# CORS_ORIGINS=["http://localhost:5173","https://your-domain.com"]
